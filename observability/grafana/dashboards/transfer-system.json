{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {"expr": "sum(rate(http_requests_total[1m]))", "legendFormat": "requests/s"}
      ],
      "title": "API Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) / clamp_min(sum(rate(http_requests_total[1m])), 0.001)",
          "legendFormat": "5xx ratio"
        }
      ],
      "title": "API 5xx Error Ratio",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "title": "API Latency",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(transfers_created_total[1m])) * 60",
          "legendFormat": "transfers/min"
        }
      ],
      "title": "Transfers Per Minute",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(transfer_amount_total[1m])) * 60",
          "legendFormat": "amount/min"
        }
      ],
      "title": "Transfer Amount Per Minute",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"max": 1, "min": 0, "unit": "percentunit"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(wallet_cache_hits_total[5m])) / clamp_min(sum(rate(wallet_cache_hits_total[5m])) + sum(rate(wallet_cache_misses_total[5m])), 0.001)",
          "legendFormat": "wallet cache hit ratio"
        }
      ],
      "title": "Wallet Cache Hit Ratio",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
      "id": 7,
      "targets": [
        {"expr": "ledger_balance_delta", "legendFormat": "ledger delta"}
      ],
      "title": "Ledger Balance Delta",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
      "id": 8,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "{{operation}} p95"
        }
      ],
      "title": "Database Query p95",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
      "id": 9,
      "targets": [
        {
          "expr": "sum(rabbitmq_queue_messages_ready) by (queue)",
          "legendFormat": "{{queue}} ready"
        },
        {
          "expr": "sum(rabbitmq_queue_messages_unacked) by (queue)",
          "legendFormat": "{{queue}} unacked"
        }
      ],
      "title": "RabbitMQ Queue Load",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "id": 10,
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count) by (state)",
          "legendFormat": "{{state}}"
        }
      ],
      "title": "PostgreSQL Connections",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "id": 11,
      "targets": [
        {"expr": "redis_memory_used_bytes", "legendFormat": "used memory"}
      ],
      "title": "Redis Memory Usage",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["transfer-system", "observability"],
  "templating": {"list": []},
  "time": {"from": "now-30m", "to": "now"},
  "timezone": "browser",
  "title": "Transfer System Overview",
  "uid": "transfer-system-overview",
  "version": 1
}
