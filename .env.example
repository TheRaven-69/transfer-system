APP_ENV=local
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/transfer_system
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
CACHE_ENABLED=true
LOG_LEVEL=INFO
NOTIFY_FAIL_RATE=0.0
NOTIFY_DELAY_SEC=2.0

# Leave empty to disable Sentry.
SENTRY_DSN=
# Defaults to APP_ENV when omitted.
SENTRY_ENVIRONMENT=local
# Set this to the deployed Git SHA or image version in CI/CD.
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
